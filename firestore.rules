rules_version = '2';

// Firestore security rules for nba-lotto.
//
// These close the biggest hole in the project: without rules, the database is
// in "test mode" and ANYONE can overwrite any lottery's results directly,
// bypassing the UI entirely. With these rules:
//   - results are publicly readable (lotteries are meant to be shared),
//   - only the admin can create/modify/delete their own lottery,
//   - a signed-in league member can add THEMSELVES as a verifier (and nothing
//     else) while a lottery is in the verification phase.
//
// Note: these rules stop third parties and verifiers from tampering. They do
// NOT, by themselves, stop a malicious ADMIN from re-running their own draw —
// that requires the commit-reveal scheme noted as a follow-up. The recorded
// `seed` makes an honest admin's draw auditable in the meantime.

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles: a user may only read and write their own.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /lotteries/{lotteryId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isAdmin() {
        return isSignedIn() && request.auth.uid == resource.data.adminId;
      }

      // Verifier write: any signed-in user may change ONLY the verifiers list
      // (and timestamp). Kept deliberately lenient so verification can never be
      // blocked during a live lottery — result fields (teams, combinations,
      // drawnCombinations, draftOrder, seed, status) remain admin-only.
      function isVerifierAppend() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return isSignedIn() && changed.hasOnly(['verifiers', 'updatedAt']);
      }

      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.adminId;
      allow update: if isAdmin() || isVerifierAppend();
      allow delete: if isAdmin();
    }
  }
}
